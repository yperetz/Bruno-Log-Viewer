{
  "name": "bruno-logs-viewer",
  "version": "0.1.0",
  "description": "Desktop app for viewing REST API logs from Bruno",
  "author": "",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-icon.js && vite build && electron-builder --win && node scripts/embed-icon.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "date-fns": "^4.1.0",
    "electron-store": "^10.0.0",
    "prismjs": "^1.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/prismjs": "^1.26.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.3",
    "vite-plugin-electron-renderer": "^0.14.6",
    "rcedit": "^5.0.2",
    "png-to-ico": "^3.0.1",
    "jimp": "^0.22.12"
  },
  "build": {
    "appId": "com.bruno-logs-viewer.app",
    "productName": "Bruno Log Viewer",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon.png",
      "build/icon.ico"
    ],
    "win": {
      "target": ["dir"],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
